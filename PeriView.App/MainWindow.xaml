<Window x:Class="PeriView.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PeriView" Height="560" Width="980" MinHeight="420" MinWidth="720"
        Background="#EFF3F8"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#EFF3F8"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#F9FBFF"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#D7DFEA"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#0A64D8"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#0B57BC"/>
        <SolidColorBrush x:Key="AccentPressedBrush" Color="#094AA0"/>
        <SolidColorBrush x:Key="SecondaryButtonBrush" Color="#E8EEF8"/>
        <SolidColorBrush x:Key="SecondaryButtonHoverBrush" Color="#DEE8F6"/>
        <SolidColorBrush x:Key="SecondaryButtonPressedBrush" Color="#D1DDF0"/>
        <SolidColorBrush x:Key="SecondaryButtonTextBrush" Color="#244A85"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#5E6977"/>
        <SolidColorBrush x:Key="HeaderTextBrush" Color="#1D242E"/>

        <DropShadowEffect x:Key="CardShadowEffect"
                  Color="#19000000"
                  BlurRadius="16"
                  ShadowDepth="2"
                  Opacity="1"/>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource AccentPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="{StaticResource SecondaryButtonTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource SecondaryButtonBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                BorderBrush="#C8D6EA"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SecondaryButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SecondaryButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlyphTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe Fluent Icons"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#EDF3FB"/>
            <Setter Property="Foreground" Value="#3A4656"/>
            <Setter Property="BorderBrush" Value="#D7DFEA"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CenterHeaderStyle" TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#1D2B3C"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridCellTextStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="Foreground" Value="#334355"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="DeviceNameTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1D2B3C"/>
        </Style>

        <Style x:Key="TimeTextStyle" TargetType="TextBlock" BasedOn="{StaticResource DataGridCellTextStyle}">
            <Setter Property="FontFamily" Value="Cascadia Mono, Consolas"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#536275"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="BadgeTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2D3F55"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="MinHeight" Value="46"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E6ECF4"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F7FAFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EAF3FF"/>
                    <Setter Property="Foreground" Value="#1D2B3C"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EEF5FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="Thumb">
            <Setter Property="Background" Value="#B8C4D6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8FA2BC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Background" Value="#EDF3FB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Margin="0,4,2,4">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" IsTabStop="False"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb MinHeight="28" Margin="1"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" IsTabStop="False"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="10"/>
                                <Setter Property="Width" Value="Auto"/>
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Storyboard x:Key="PageLoadStoryboard">
            <DoubleAnimation Storyboard.TargetName="HeaderCard"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.24"/>
            <DoubleAnimation Storyboard.TargetName="HeaderCardTranslate"
                             Storyboard.TargetProperty="Y"
                             From="10" To="0" Duration="0:0:0.24"/>

            <DoubleAnimation Storyboard.TargetName="HintText"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" BeginTime="0:0:0.06" Duration="0:0:0.22"/>
            <DoubleAnimation Storyboard.TargetName="HintTextTranslate"
                             Storyboard.TargetProperty="Y"
                             From="8" To="0" BeginTime="0:0:0.06" Duration="0:0:0.22"/>

            <DoubleAnimation Storyboard.TargetName="GridCard"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" BeginTime="0:0:0.1" Duration="0:0:0.26"/>
            <DoubleAnimation Storyboard.TargetName="GridCardTranslate"
                             Storyboard.TargetProperty="Y"
                             From="14" To="0" BeginTime="0:0:0.1" Duration="0:0:0.26"/>

            <DoubleAnimation Storyboard.TargetName="StatusCard"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" BeginTime="0:0:0.16" Duration="0:0:0.22"/>
            <DoubleAnimation Storyboard.TargetName="StatusCardTranslate"
                             Storyboard.TargetProperty="Y"
                             From="10" To="0" BeginTime="0:0:0.16" Duration="0:0:0.22"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource PageLoadStoryboard}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid Margin="20">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#F4F8FE" Offset="0"/>
                <GradientStop Color="#EAF1FA" Offset="0.5"/>
                <GradientStop Color="#E6EEF9" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Canvas Grid.RowSpan="4" IsHitTestVisible="False">
            <Ellipse Width="360" Height="360" Fill="#48FFFFFF" Canvas.Left="-90" Canvas.Top="-120"/>
            <Ellipse Width="280" Height="280" Fill="#2CA7C7F3" Canvas.Right="-80" Canvas.Top="-40"/>
            <Ellipse Width="220" Height="220" Fill="#2ABDD4F8" Canvas.Right="120" Canvas.Bottom="-90"/>
        </Canvas>

        <Border x:Name="HeaderCard"
                Grid.Row="0"
                Margin="0 0 0 12"
                Padding="16"
                CornerRadius="12"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                Opacity="0"
                Effect="{StaticResource CardShadowEffect}">
            <Border.RenderTransform>
                <TranslateTransform x:Name="HeaderCardTranslate" Y="10"/>
            </Border.RenderTransform>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="PeriView - 外设状态监测"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource HeaderTextBrush}"
                           VerticalAlignment="Center"/>
                <Button Grid.Column="1" Width="110" Height="36" Margin="16 0 0 0" Command="{Binding RefreshCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE72C;" Style="{StaticResource GlyphTextStyle}"/>
                        <TextBlock Text="刷新" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Width="140" Height="36" Margin="10 0 0 0" Command="{Binding ExportDebugPropertiesCommand}" Style="{StaticResource SecondaryButtonStyle}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE898;" Style="{StaticResource GlyphTextStyle}"/>
                        <TextBlock Text="调试导出" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <TextBlock x:Name="HintText"
                   Grid.Row="1"
                   Text="当前可枚举 BLE/经典蓝牙设备；优先读取 BLE 标准电池服务，经典蓝牙会尝试通过同设备 BLE 端点回退读取，后续可扩展 2.4G/HID/厂商 SDK。"
                   Foreground="{StaticResource MutedTextBrush}"
                   Margin="2 0 2 12"
                   FontSize="13"
                   Opacity="0">
            <TextBlock.RenderTransform>
                <TranslateTransform x:Name="HintTextTranslate" Y="8"/>
            </TextBlock.RenderTransform>
        </TextBlock>

        <Border x:Name="GridCard"
                Grid.Row="2"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="1"
                SnapsToDevicePixels="True"
                Opacity="0"
                Effect="{StaticResource CardShadowEffect}">
            <Border.RenderTransform>
                <TranslateTransform x:Name="GridCardTranslate" Y="14"/>
            </Border.RenderTransform>
            <DataGrid x:Name="DevicesGrid"
                      ItemsSource="{Binding Devices}"
                      SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      AllowDrop="True"
                      PreviewMouseLeftButtonDown="DevicesGrid_PreviewMouseLeftButtonDown"
                      MouseMove="DevicesGrid_MouseMove"
                      DragOver="DevicesGrid_DragOver"
                      DragLeave="DevicesGrid_DragLeave"
                      Drop="DevicesGrid_Drop"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#E6ECF4"
                      VerticalGridLinesBrush="Transparent"
                      RowHeaderWidth="0"
                      BorderThickness="0"
                      Background="Transparent"
                      AlternationCount="2">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="设备名称" Binding="{Binding Name}" Width="2.25*" ElementStyle="{StaticResource DeviceNameTextStyle}"/>

                    <DataGridTemplateColumn Header="连接类型" Width="0.9*" HeaderStyle="{StaticResource CenterHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="8,3"
                                        CornerRadius="8"
                                        HorizontalAlignment="Center"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F0F4FA"/>
                                            <Setter Property="BorderBrush" Value="#D1DCEB"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding TransportType}" Value="蓝牙">
                                                    <Setter Property="Background" Value="#E7F4FF"/>
                                                    <Setter Property="BorderBrush" Value="#BFDDF8"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TransportType}" Value="2.4G">
                                                    <Setter Property="Background" Value="#F2F6E8"/>
                                                    <Setter Property="BorderBrush" Value="#D7E4B5"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding TransportType}" Value="其他">
                                                    <Setter Property="Background" Value="#F6F1FA"/>
                                                    <Setter Property="BorderBrush" Value="#DDD0EA"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding TransportType}" Style="{StaticResource BadgeTextStyle}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="电量" Width="*" HeaderStyle="{StaticResource CenterHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="8,3"
                                        CornerRadius="8"
                                        HorizontalAlignment="Center"
                                        Background="#E8F0FC"
                                        BorderBrush="#C7DAF4"
                                        BorderThickness="1">
                                    <TextBlock Text="{Binding BatteryText}" Style="{StaticResource BadgeTextStyle}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="充电中" Width="*" HeaderStyle="{StaticResource CenterHeaderStyle}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Padding="8,3"
                                        CornerRadius="8"
                                        HorizontalAlignment="Center"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#F0F4FA"/>
                                            <Setter Property="BorderBrush" Value="#D1DCEB"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsChargingText}" Value="是">
                                                    <Setter Property="Background" Value="#E8F7EE"/>
                                                    <Setter Property="BorderBrush" Value="#BDE5CA"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsChargingText}" Value="否">
                                                    <Setter Property="Background" Value="#F5F7FB"/>
                                                    <Setter Property="BorderBrush" Value="#D8E0EC"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsChargingText}" Value="未知">
                                                    <Setter Property="Background" Value="#FDF3E8"/>
                                                    <Setter Property="BorderBrush" Value="#F2D2AE"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding IsChargingText}" Style="{StaticResource BadgeTextStyle}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="更新时间" Binding="{Binding LastUpdatedText}" Width="1.45*" ElementStyle="{StaticResource TimeTextStyle}" HeaderStyle="{StaticResource CenterHeaderStyle}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border x:Name="StatusCard"
                Grid.Row="3"
                Margin="0 12 0 0"
                Padding="12,10"
                CornerRadius="10"
                Background="#F5F8FD"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                Opacity="0"
                Effect="{StaticResource CardShadowEffect}">
            <Border.RenderTransform>
                <TranslateTransform x:Name="StatusCardTranslate" Y="10"/>
            </Border.RenderTransform>
            <TextBlock Text="{Binding StatusMessage}" Foreground="#3E4A5A" FontSize="13"/>
        </Border>
    </Grid>
</Window>
